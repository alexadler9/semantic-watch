# Telegram token from @BotFather.
TELEGRAM_BOT_TOKEN=replace_me

# Comma-separated Telegram user IDs that are always allowed.
# May be empty when ACCESS_KEY is configured.
TELEGRAM_OWNER_IDS=

# Optional shared activation key. Remove it after all required users are activated.
ACCESS_KEY=replace_with_a_long_random_value

# DeepSeek API.
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=30000

DATA_FILE=./data/store.json
MAX_ACTIVE_WATCHES_PER_USER=5
MAX_LLM_CALLS_PER_DAY=50
MATCH_CONFIDENCE_THRESHOLD=0.8

FETCH_TIMEOUT_MS=10000
MAX_RESPONSE_BYTES=2097152
MAX_PAGE_TEXT_CHARS=30000
MAX_DIFF_CHARS=12000

# Background monitoring.
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
DEFAULT_CHECK_INTERVAL_MINUTES=30
ERROR_RETRY_MINUTES=5
NOTIFICATION_RETRY_MINUTES=5
MAX_CHECKS_PER_TICK=10
MAX_NOTIFICATION_ATTEMPTS=5

# Local demonstration exception. Only exact DEMO_URL is accepted from a user.
DEMO_MODE=true
DEMO_URL=http://127.0.0.1:3001/
